# Docker image tag
ENV=prod-latest
APP_ENV=prod

# Database credentials (change these!)
AUTH_DB_PASSWORD=changeme
POST_DB_PASSWORD=changeme
MODERATION_DB_PASSWORD=changeme
SOCIAL_DB_PASSWORD=changeme
FEED_DB_PASSWORD=changeme

# Database URLs
AUTH_DATABASE_URL=postgresql://twomice:${AUTH_DB_PASSWORD}@auth-db:5432/auth
POST_DATABASE_URL=postgresql://twomice:${POST_DB_PASSWORD}@post-db:5432/post
MODERATION_DATABASE_URL=postgresql://twomice:${MODERATION_DB_PASSWORD}@moderation-db:5432/moderation
SOCIAL_DATABASE_URL=postgresql://twomice:${SOCIAL_DB_PASSWORD}@social-db:5432/social
FEED_DATABASE_URL=postgresql://twomice:${FEED_DB_PASSWORD}@social-feed-db:5432/social_feed
