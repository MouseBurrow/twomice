# Database credentials (local dev via db/compose.yaml)
AUTH_DB_USER=twomice
AUTH_DB_PASSWORD=twomice
AUTH_DB_NAME=auth
AUTH_DB_PORT=5432

POST_DB_USER=twomice
POST_DB_PASSWORD=twomice
POST_DB_NAME=post
POST_DB_PORT=5433

# Per-service database URLs
AUTH_DATABASE_URL=postgresql://${AUTH_DB_USER:-twomice}:${AUTH_DB_PASSWORD:-twomice}@localhost:${AUTH_DB_PORT:-5432}/${AUTH_DB_NAME:-auth}
POST_DATABASE_URL=postgresql://${POST_DB_USER:-twomice}:${POST_DB_PASSWORD:-twomice}@localhost:${POST_DB_PORT:-5433}/${POST_DB_NAME:-post}

# Service configuration
PORT=8080
